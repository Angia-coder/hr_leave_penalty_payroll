<odoo>

    <record id="view_hr_leave_form_inherit_penalty" model="ir.ui.view">
        <field name="name">hr.leave.form.penalty</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">
                <group string="Penalty">
                    <field name="is_wrong_leave"/>
                    <field name="penalty_rate"/>
                    <field name="penalty_hours" readonly="1"/>
                    <field name="approved_by" readonly="1"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
